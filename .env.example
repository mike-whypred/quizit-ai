# Anthropic API Key (for quiz generation and review)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Jina AI API Key (optional but recommended for better rate limits on URL extraction)
# Get your API key from https://jina.ai/
JINA_API_KEY=your_jina_api_key_here

# Claude Model to use (optional, defaults to claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
